# Local development defaults. Change these before any shared or production deployment.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=legal_ai
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/legal_ai
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=legal-documents
MINIO_SECURE=false
SECRET_KEY=change-me-before-production
N8N_WEBHOOK_SECRET=dev-only-legal-ai-n8n-secret
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_BASE_URL=
LLM_MODEL=openai/gpt-4o-mini
VISION_MODEL=
VISION_API_KEY=
VISION_BASE_URL=
SUMMARY_AGENT_MODEL=
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
EXTERNAL_RESEARCH_ENABLED=true
EXTERNAL_RESEARCH_PROVIDER=tavily
EXTERNAL_RESEARCH_MAX_RESULTS=5
EXTERNAL_RESEARCH_TIMEOUT_SECONDS=20
TAVILY_API_KEY=
SERPAPI_API_KEY=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
SPEECHMATICS_API_KEY=
SPEECHMATICS_BASE_URL=https://asr.api.speechmatics.com/v2
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_ENABLE_AUTODETECT=true
SPEECHMATICS_POLL_INTERVAL_SECONDS=2
SPEECHMATICS_MAX_WAIT_SECONDS=240
LOCAL_TRANSCRIPTION_MODEL=openai/whisper-tiny
TRANSCRIPTION_DEVICE=auto
LOCAL_TRANSCRIPTION_PREFER_LOCAL_FILES=true
TRANSCRIPTION_PREWARM_ON_STARTUP=true
TRANSCRIPTION_REMOTE_ENABLED=true
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=legal-ai-platform
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true
RETRIEVAL_LEXICAL_WEIGHT=0.4
RETRIEVAL_SEMANTIC_WEIGHT=0.6
RETRIEVAL_MIN_SCORE=0.05
RETRIEVAL_FILTER_NON_LEGAL_TEST=true
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
CORS_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://localhost:5174,http://127.0.0.1:5174
CLIENT_PORTAL_FIRM_NAME=Arbi Mostaissier
PORTAL_EMAIL_FROM=arbimostaisser@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=law-firm@example.com
SMTP_PASSWORD=change-me
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=20
PORTAL_LOGIN_CODE_EXPIRE_MINUTES=10
PORTAL_ALLOW_CONSOLE_CODE_FALLBACK=true
AUTH_LOGIN_MAX_ATTEMPTS=6
AUTH_LOGIN_WINDOW_SECONDS=300
AUTH_LOGIN_BLOCK_SECONDS=900
PORTAL_LOGIN_MAX_ATTEMPTS=6
PORTAL_LOGIN_WINDOW_SECONDS=300
PORTAL_LOGIN_BLOCK_SECONDS=900
PORTAL_VERIFY_MAX_ATTEMPTS=8
PORTAL_VERIFY_WINDOW_SECONDS=300
PORTAL_VERIFY_BLOCK_SECONDS=900
DOCUMENT_UPLOAD_MAX_MB=20
VOICE_UPLOAD_MAX_MB=25
# AI engineering feature flags (default OFF — flip on after eval).
# HyDE + multi-query expansion + Reciprocal Rank Fusion in retrieval.
LAI_ENABLE_HYDE_RRF=
# NLI-based per-claim citation faithfulness scoring.
LAI_ENABLE_NLI_FAITHFULNESS=
# Pydantic-validated structured IRAC answer (with repair loop).
LAI_ENABLE_STRUCTURED_IRAC=
