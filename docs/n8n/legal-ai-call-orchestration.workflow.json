            "id": "25a2d68a-6e70-4f9d-b0c5-5f0ad1fdc502",
            "name": "Route Event",
            "type": "n8n-nodes-base.switch",
            "typeVersion": 2,
            "position": [
                540,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const backendBaseUrl = ($env.LEGAL_AI_BACKEND_URL || 'http://host.docker.internal:8000').replace(/\/$/, '');\nconst whatsappTo = $json.client_phone || $json.caller_phone || '';\nconst consentMessage = $json.consent_message || `Hello, this is Legal AI regarding case #${$json.case_id}. Please reply YES to confirm consent for this WhatsApp call and recording.`;\n\nreturn [{\n  json: {\n    ...$json,\n    backendBaseUrl,\n    whatsappTo,\n    consentMessage,\n    backendCallbackUrl: `${backendBaseUrl}/integrations/n8n/events`,\n  },\n}];"
            },
            "id": "76f6b0a6-2b71-4b65-8dd0-8ed2732f4c03",
            "name": "Build Consent Payload",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                780,
                180
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "={{ $env.WHATSAPP_SEND_ENDPOINT }}",
                "authentication": "none",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "={{ $env.WHATSAPP_SEND_AUTH_TOKEN ? `Bearer ${$env.WHATSAPP_SEND_AUTH_TOKEN}` : '' }}"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "contentType": "json",
                "jsonBody": "={\n  \"to\": $json.whatsappTo,\n  \"message\": $json.consentMessage,\n  \"metadata\": {\n    \"call_session_id\": $json.call_session_id,\n    \"case_id\": $json.case_id,\n    \"client_id\": $json.client_id,\n    \"tenant_id\": $json.tenant_id\n  }\n}",
                "options": {
                    "ignoreResponseCode": true
                }
            },
            "id": "c9a8ae05-b2a6-4fb8-9a64-1c5d4f6bb104",
            "name": "Send WhatsApp Consent",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                1020,
                180
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "={{ $json.backendCallbackUrl }}",
                "authentication": "none",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "name": "X-N8N-SECRET",
                            "value": "={{ $env.N8N_WEBHOOK_SECRET || '' }}"
                        }
                    ]
                },
                "sendBody": true,
                "contentType": "json",
                "jsonBody": "={\n  \"event_type\": \"consent.request.sent\",\n  \"call_session_id\": $json.call_session_id,\n  \"voice_recording_id\": null,\n  \"provider_call_id\": null,\n  \"client_phone\": $json.client_phone,\n  \"caller_phone\": $json.caller_phone,\n  \"consent_message\": $json.consentMessage,\n  \"status\": \"awaiting_consent\"\n}",
                "options": {
                    "ignoreResponseCode": true
                }
            },
            "id": "b43c4fa4-3c4a-4b37-b5ec-2d12b2b6e205",
            "name": "Notify Backend Consent Sent",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                1260,
                180
            ]
        },
        {
            "parameters": {
                "responseCode": 200,
                "responseBody": "={\n  \"success\": true,\n  \"message\": \"Consent request was sent to the client.\",\n  \"call_session_id\": $json.call_session_id,\n  \"delivery_mode\": \"n8n\"\n}",
                "options": {}
            },
            "id": "8f6d7d6b-8c5a-42d5-95e2-3c8f4b2b8f06",
            "name": "Respond Consent Sent",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                1500,
                180
            ]
        },
        {
            "parameters": {
                "jsCode": "const bodyText = String($json.body || '').trim();\nconst normalized = bodyText.toLowerCase();\nconst accepted = ['yes', 'y', 'ok', 'okay', 'oui'].includes(normalized) || normalized.startsWith('yes ') || normalized.startsWith('oui ');\n\nreturn [{\n  json: {\n    ...$json,\n    normalizedReply: normalized,\n    consentAccepted: accepted,\n    backendBaseUrl: ($env.LEGAL_AI_BACKEND_URL || 'http://host.docker.internal:8000').replace(/\/$/, ''),\n    backendCallbackUrl: `${($env.LEGAL_AI_BACKEND_URL || 'http://host.docker.internal:8000').replace(/\/$/, '')}/integrations/n8n/events`,\n  },\n}];"
            },
            "id": "bfaad89f-1a0e-45a0-a8d0-8a87a85d3f07",
            "name": "Normalize Consent Reply",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                780,
                360
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": false,
                        "leftValue": "",
                        "typeValidation": "strict",
                        "version": 2
                    },
                    "combinator": "and",
                    "conditions": [
                        {
                            "leftValue": "={{ $json.consentAccepted }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "true"
                            }
                        }
                    ]
                }
            },
            "id": "26168a50-9f4b-43d3-b48e-cc1fa4d1e408",
            "name": "Reply Accepted?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                1020,
                360
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "={{ $json.backendCallbackUrl }}",
