                "responseBody": "={\n  \"success\": true,\n  \"message\": \"Transcript forwarded to Legal AI backend.\",\n  \"call_session_id\": $json.call_session_id\n}",
                "options": {}
            },
            "id": "1bc9f7cb-d3c2-49da-86ef-1dfbe8cbf515",
            "name": "Respond Transcript Forwarded",
