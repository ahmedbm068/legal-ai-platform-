                        }
                    ]
                },
                "sendBody": true,
                "contentType": "json",
                "jsonBody": "={\n  \"event_type\": \"consent.reply.received\",\n  \"call_session_id\": $json.call_session_id,\n  \"voice_recording_id\": null,\n  \"provider_call_id\": null,\n  \"client_phone\": $json.client_phone,\n  \"caller_phone\": $json.caller_phone,\n  \"body\": $json.body,\n  \"status\": \"ready\"\n}",
                "options": {
                    "ignoreResponseCode": true
                }
            },
            "id": "f2cf3d8a-7cc0-4f1f-8c73-8f0b6fd3f209",
            "name": "Notify Backend Consent Accepted",
