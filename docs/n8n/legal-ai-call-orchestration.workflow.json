                "jsonBody": "={\n  \"event_type\": \"transcription.completed\",\n  \"call_session_id\": $json.call_session_id,\n  \"voice_recording_id\": $json.voice_recording_id || null,\n  \"provider_call_id\": $json.provider_call_id || null,\n  \"client_phone\": $json.client_phone,\n  \"caller_phone\": $json.caller_phone,\n  \"transcript_text\": $json.transcript_text || null,\n  \"transcript_source\": $json.transcript_source || null,\n  \"transcript_language\": $json.transcript_language || null,\n  \"conversation_turns\": $json.conversation_turns || [],\n  \"status\": $json.status || \"completed\"\n}",
                "options": {
                    "ignoreResponseCode": true
                }
            },
            "id": "a6d7f0d1-0d14-4d0c-9bb7-6f8bcbf9f414",
            "name": "Forward Transcript Update",
