                "jsonBody": "={\n  \"call_session_id\": $json.call_session_id,\n  \"client_phone\": $json.client_phone,\n  \"caller_phone\": $json.caller_phone,\n  \"case_id\": $json.case_id\n}",
                "options": {
                    "ignoreResponseCode": true
                }
            },
            "id": "d0bf774d-1cc2-4fa6-9f78-c53bd4f70a10",
            "name": "Start Call Provider",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                1500,
                280
