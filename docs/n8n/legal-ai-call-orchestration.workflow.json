        },
        {
            "parameters": {
                "responseCode": 200,
                "responseBody": "={\n  \"success\": true,\n  \"message\": \"Consent accepted. Call start request was sent.\",\n  \"call_session_id\": $json.call_session_id,\n  \"accepted\": true\n}",
                "options": {}
            },
            "id": "1be1cba6-d6ef-46ef-8c57-1d9b8f15db11",
            "name": "Respond Consent Accepted",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                1740,
